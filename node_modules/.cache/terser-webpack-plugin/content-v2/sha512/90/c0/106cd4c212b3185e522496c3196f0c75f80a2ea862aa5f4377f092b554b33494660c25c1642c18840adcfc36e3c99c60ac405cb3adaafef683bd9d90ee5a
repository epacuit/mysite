      {course.node.description}\\n      </div>\\n      {course.node.website !== '' && (\\n        <div>\\n          <a\\n            href={course.node.website}\\n            target=\\\"_blank\\\"\\n            rel=\\\"noopener noreferrer\\\"\\n            className=\\\"button is-small is-light\\\"\\n            style={{ marginRight: 20 }}\\n          >\\n            <span className=\\\"icon is-small\\\">\\n              {' '}\\n              <FaExternalLinkAlt />{' '}\\n            </span>\\n            &nbsp;&nbsp;website\\n          </a>\\n        </div>\\n      )}\\n    </Li>\\n  ))\\n}\\n\\nconst PreviousCourses = ({ activePage, children }) => (\\n  <StaticQuery\\n    query={graphql`\\n      query {\\n        allPastCoursesCsv {\\n          edges {\\n            node {\\n              description\\n              semester\\n              website\\n              school\\n            }\\n          }\\n        }\\n      }\\n    `}\\n    render={data => {\\n      const schools = [\\n        'Carnegie Mellon University',\\n        'Tilburg University',\\n        'Stanford University',\\n        'Institute for Logic, Language and Computation, University of Amsterdam',\\n        'Brooklyn College',\\n        'New York University',\\n        'Case Western Reserve University',\\n      ]\\n\\n      const schoolList = schools.map((school, idx) => (\\n        <div key={idx}>\\n          <div\\n            className=\\\"has-text-weight-semibold\\\"\\n            style={{ marginBottom: 10 }}\\n          >\\n            {school}\\n          </div>\\n          <Ul>\\n            {courseList(\\n              data.allPastCoursesCsv.edges.filter(c => c.node.school === school)\\n            )}\\n          </Ul>\\n        </div>\\n      ))\\n      return <>{schoolList}</>\\n    }}\\n  />\\n)\\n\\nexport default PreviousCourses\\n\",\"import React, { Component } from 'react'\\nimport Layout from '../components/layout'\\nimport PreviousCourses from '../components/previousCourseList'\\n